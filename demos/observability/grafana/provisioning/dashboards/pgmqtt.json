{
  "uid": "pgmqtt-obs",
  "title": "pgmqtt — Broker Observability",
  "description": "Real-time broker metrics sourced from pgmqtt_metrics() via postgres_exporter.",
  "tags": ["pgmqtt"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Connections",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50,   "color": "yellow" },
              { "value": 100,  "color": "red" }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "pg_pgmqtt_metric_value{metric_name=\"connections_current\"}",
        "legendFormat": "connections"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Messages Received / s",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "blue" }]
          }
        }
      },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"msgs_received\"}[$__rate_interval])",
        "legendFormat": "msgs/s"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Messages Sent / s",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "purple" }]
          }
        }
      },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"msgs_sent\"}[$__rate_interval])",
        "legendFormat": "msgs/s"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DB Batches / s",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "orange" }]
          }
        }
      },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"db_batches_committed\"}[$__rate_interval])",
        "legendFormat": "batches/s"
      }]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Connection Activity",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "pg_pgmqtt_metric_value{metric_name=\"connections_current\"}",
          "legendFormat": "active"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"connections_accepted\"}[$__rate_interval])",
          "legendFormat": "accepted/s"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"disconnections_clean\"}[$__rate_interval])",
          "legendFormat": "disconnected/s"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"connections_rejected\"}[$__rate_interval])",
          "legendFormat": "rejected/s"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Message Throughput",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"msgs_received\"}[$__rate_interval])",
          "legendFormat": "received/s"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"msgs_sent\"}[$__rate_interval])",
          "legendFormat": "sent/s"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"msgs_dropped_queue_full\"}[$__rate_interval])",
          "legendFormat": "dropped (queue full)/s"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Inbound Pipeline (MQTT → DB)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"inbound_writes_ok\"}[$__rate_interval])",
          "legendFormat": "writes ok/s"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"inbound_writes_failed\"}[$__rate_interval])",
          "legendFormat": "writes failed/s"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"db_batches_committed\"}[$__rate_interval])",
          "legendFormat": "batches/s"
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "CDC & Error Rates",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"cdc_events_processed\"}[$__rate_interval])",
          "legendFormat": "CDC events/s"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"db_session_errors\"}[$__rate_interval]) + rate(pg_pgmqtt_metric_value{metric_name=\"db_message_errors\"}[$__rate_interval]) + rate(pg_pgmqtt_metric_value{metric_name=\"db_subscription_errors\"}[$__rate_interval])",
          "legendFormat": "DB errors/s"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"cdc_render_errors\"}[$__rate_interval]) + rate(pg_pgmqtt_metric_value{metric_name=\"cdc_slot_errors\"}[$__rate_interval]) + rate(pg_pgmqtt_metric_value{metric_name=\"cdc_persist_errors\"}[$__rate_interval])",
          "legendFormat": "CDC errors/s"
        }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Bytes In / Out",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"bytes_received\"}[$__rate_interval])",
          "legendFormat": "received"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"bytes_sent\"}[$__rate_interval])",
          "legendFormat": "sent"
        }
      ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Session Lifecycle",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"sessions_created\"}[$__rate_interval])",
          "legendFormat": "created/s"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"sessions_resumed\"}[$__rate_interval])",
          "legendFormat": "resumed/s"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(pg_pgmqtt_metric_value{metric_name=\"sessions_expired\"}[$__rate_interval])",
          "legendFormat": "expired/s"
        }
      ]
    }
  ]
}
